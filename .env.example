# rag-evals configuration.
# Everything is environment-driven; there are no hardcoded defaults for
# anything that costs money or selects a model.

# --- Retrieval ---
# Number of documents retrieved per query.
RAGEVALS_TOP_K=5
# Retriever backend: "bm25" (offline, no API needed) or "dense" (embeddings API).
RAGEVALS_RETRIEVER=bm25

# --- Dense retrieval (only used when RAGEVALS_RETRIEVER=dense) ---
# Provider for embeddings. Currently supported: "openai".
RAGEVALS_EMBEDDING_PROVIDER=
# Embedding model name. Required when dense retrieval is enabled.
RAGEVALS_EMBEDDING_MODEL=
OPENAI_API_KEY=

# --- LLM-as-judge (optional; enables generation-quality metrics) ---
# Provider: "anthropic" or "openai". Leave empty to disable the judge.
RAGEVALS_JUDGE_PROVIDER=
# Judge model name. Required when the judge is enabled.
RAGEVALS_JUDGE_MODEL=
ANTHROPIC_API_KEY=

# --- Regression gate ---
# Maximum allowed absolute drop per metric before `ragevals check` fails.
RAGEVALS_REGRESSION_TOLERANCE=0.02
